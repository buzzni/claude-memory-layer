{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-memory-layer.local/schemas/memory-field-dataset-v1.json",
  "title": "Local Memory Field Evaluation Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "generatedAt",
    "localOnly",
    "rawQueryContentIncluded",
    "generation",
    "cases"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "localOnly": { "const": true },
    "rawQueryContentIncluded": { "const": true },
    "generation": {
      "type": "object",
      "required": ["requestedCases", "positiveCases", "counterfactualCases", "unrelatedCases", "promotedPositiveCases", "sourceSessions"],
      "properties": {
        "requestedCases": { "type": "integer", "minimum": 1 },
        "positiveCases": { "type": "integer", "minimum": 1 },
        "counterfactualCases": { "type": "integer", "minimum": 0 },
        "unrelatedCases": { "type": "integer", "minimum": 0 },
        "promotedPositiveCases": { "type": "integer", "minimum": 0 },
        "sourceSessions": { "type": "integer", "minimum": 1 }
        ,"difficultyCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "queryStyleCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caseId", "kind", "query", "expectedEventIds", "sourceLevel", "sourceDigest"],
        "properties": {
          "caseId": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["positive", "counterfactual", "unrelated"] },
          "query": { "type": "string", "minLength": 1 },
          "expectedEventIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sourceLevel": { "enum": ["L0", "L1", "L2", "L3", "L4", "unknown"] },
          "sourceDigest": { "type": "string", "pattern": "^[a-f0-9]{16}$" },
          "difficulty": { "enum": ["easy", "standard", "hard"] },
          "queryStyle": {
            "enum": ["exact", "contextual", "compressed_clues", "paraphrased_clues", "noisy_clues", "plausible_counterfactual", "unrelated"]
          }
        }
      }
    }
  }
}
